{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gameplanner-tauri",
  "version": "0.2.0",
  "identifier": "com.woody.gameplanner-tauri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Game Planner",
        "width": 1280,
        "height": 720,
        "maximized": true,
        "resizable": true,
        "fullscreen": false,
        "focus": true,
        "visible": true,
        "decorations": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$DOWNLOAD/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNCM0E2RThCNDgyREI4NkIKUldScnVDMUlpMjQ2TzcrWW5iWXkxZXVSK2hvWkpXTHA4a1BqeUxwUlY2aFNsUnhUTnZIQ1FPbloK",
      "endpoints": [
        "https://github.com/zzamjak-cloud/GamePlanner/releases/download/latest/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    },
    "deep-link": {
      "desktop": {
        "schemes": ["gameplanner"]
      }
    }
  }
}
